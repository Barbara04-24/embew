<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tampilan Video di GitHub</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: #f4f4f9;
            padding: 20px;
        }
        .video-container {
            position: relative;
            max-width: 640px;
            width: 100%;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        video {
            width: 100%;
            height: auto;
            display: block;
        }
        .controls {
            display: flex;
            gap: 10px;
            padding: 10px;
            background: #333;
            justify-content: center;
        }
        button {
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            background-color: #007bff;
            color: white;
            cursor: pointer;
            font-size: 14px;
        }
        button:hover {
            background-color: #0056b3;
        }
        span {
            color: white;
            font-size: 14px;
            align-self: center;
        }
    </style>
</head>
<body>

    <h2>Demo Video Player</h2>
    <div class="video-container">
        <!-- https://github.com/user-attachments/assets/34c7bfb2-44cc-40e6-a2e7-17453fc90af1 -->
        <video id="myVideo" src="https://w3schools.com"></video>
        
        <div class="controls">
            <button id="playPauseBtn">Play</button>
            <button id="muteBtn">Mute</button>
            <span id="timeDisplay">0:00 / 0:00</span>
        </div>
    </div>

